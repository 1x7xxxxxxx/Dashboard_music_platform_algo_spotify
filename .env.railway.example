# Railway environment variables — copy into your Railway service settings
# All values marked REQUIRED must be set before deployment.

# ─── Database ──────────────────────────────────────────────────────────────
# Auto-injected by Railway when you add the PostgreSQL plugin.
# Set manually only if using an external Postgres instance.
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ─── REST API (Brick 14) ───────────────────────────────────────────────────
# REQUIRED: JWT signing secret — generate with: openssl rand -hex 32
API_SECRET_KEY=replace_with_a_random_64_char_hex_string

# ─── Airflow (optional) ────────────────────────────────────────────────────
# Leave blank to disable DAG trigger buttons in the dashboard.
AIRFLOW_BASE_URL=https://your-airflow-instance.example.com
AIRFLOW_USERNAME=admin
AIRFLOW_PASSWORD=admin

# ─── Stripe billing (Brick 21) ─────────────────────────────────────────────
# Required if the dashboard exposes the billing/subscription tabs.
# STRIPE_SECRET_KEY     — sk_live_... or sk_test_... (server-side; never expose)
# STRIPE_WEBHOOK_SECRET — whsec_... (validates POST /api/stripe/webhook events)
# STRIPE_CHECKOUT_URL   — public checkout URL shown in the dashboard
# STRIPE_PORTAL_URL     — Stripe customer portal URL (subscription management)
# Leave blank to disable billing UI gracefully (see src/dashboard/views/billing.py).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CHECKOUT_URL=
STRIPE_PORTAL_URL=

# ─── Streamlit (auto-injected by Railway) ──────────────────────────────────
# PORT is set by Railway automatically — do not override.
# PORT=8501

# ─── Not required on Railway ───────────────────────────────────────────────
# Collector API keys (SPOTIFY_CLIENT_ID, META_APP_ID, YOUTUBE_API_KEY, etc.)
# are NOT needed here: collectors run in the local Airflow stack, not Railway.
# The Railway dashboard/API only read pre-aggregated data from Postgres.
