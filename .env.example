# ==============================================
# CONFIGURATION ENVIRONNEMENT - EXAMPLE
# ==============================================
# Copiez ce fichier en .env et remplissez avec vos vraies valeurs

# === Base de Données PostgreSQL ===
DATABASE_HOST=localhost
DATABASE_PORT=5433
DATABASE_NAME=spotify_etl
DATABASE_USER=postgres
DATABASE_PASSWORD=VOTRE_MOT_DE_PASSE_SECURISE

# === Spotify API ===
SPOTIFY_CLIENT_ID=votre_client_id_32_caracteres
SPOTIFY_CLIENT_SECRET=votre_client_secret_32_caracteres
SPOTIFY_REDIRECT_URI=http://localhost:8888/callback

# === Meta Ads API ===
META_APP_ID=votre_app_id
META_APP_SECRET=votre_app_secret_32_caracteres
META_ACCESS_TOKEN=votre_access_token_long
META_AD_ACCOUNT_ID=act_123456789
META_API_VERSION=v21.0

# === Airflow Configuration ===
AIRFLOW_HOME=C:\Users\timot\Desktop\Dashboard_music_platform_algo_spotify\airflow
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://postgres:VOTRE_PASSWORD@localhost:5433/airflow_db
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__CORE__FERNET_KEY=GENERER_AVEC_python_fernet
AIRFLOW__CORE__LOAD_EXAMPLES=False

# === Alertes (Optionnel) ===
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/VOTRE/WEBHOOK/URL
ALERT_EMAIL=votre-email@example.com

# === MCP Servers (Claude Code) ===
# Variables consommées par .mcp.json — exporter via ~/.bashrc ou .env.local
# DB_PASSWORD : mot de passe Postgres (identique à DATABASE_PASSWORD ci-dessus)
DB_PASSWORD=VOTRE_MOT_DE_PASSE_SECURISE
# GITHUB_TOKEN : Personal Access Token (scopes : repo, read:org) — github.com/settings/tokens
GITHUB_TOKEN=ghp_votre_personal_access_token
# AIRFLOW_ADMIN_PASSWORD : mot de passe admin Airflow (cf. service airflow-init dans docker-compose.yml)
AIRFLOW_ADMIN_PASSWORD=VOTRE_PASSWORD_AIRFLOW
